# Backend
PORT=8080
BACKEND_IMAGE=tuusuario/inventario-backend:1.0
POSTGRES_DB=inventario_chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=jdbc:postgresql://localhost:5432/inventario_chatbot
DB_USERNAME=postgres
DB_PASSWORD=postgres
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_EXPIRATION_MINUTES=60

# IA / Groq
GROQ_API_KEY=put-your-groq-key-here
GROQ_BASE_URL=https://api.groq.com/openai
AI_MODEL=openai/gpt-oss-120b
AI_TEMPERATURE=0.7

# Servicios externos
CONSUMO_ML_URL=http://127.0.0.1:8081
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_UPLOADS_ITEMS_PATH=/app/uploads/items
APP_UPLOADS_ITEMS_PUBLIC_BASE_URL=/uploads/items
